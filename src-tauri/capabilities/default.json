{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for OpenDeskTools application windows",
  "windows": [
    "main",
    "clipboard-surface",
    "clipboard-preview-surface",
    "tool-menu-surface",
    "qr-toast-surface"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging"
  ]
}
