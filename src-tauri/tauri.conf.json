{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDeskTools",
  "version": "0.1.0",
  "identifier": "com.opendesktools.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDeskTools",
        "label": "main",
        "width": 1080,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
