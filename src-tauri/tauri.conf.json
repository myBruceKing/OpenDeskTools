{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDeskTools",
  "version": "0.1.0",
  "identifier": "com.mybruceking.opendesktools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenDeskTools",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": ["icons/icon.ico"]
  }
}
